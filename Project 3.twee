  display: none !important;
}

body {
  background-color: #111;
  color: #ddd;
  font-family: Georgia, serif;
  line-height: 1.6;
}

a {
  color: #9ecbff;
  text-decoration: none;
}

a:hover {
  color: #c7e1ff;
  text-decoration: underline;
}

tw-story {
  max-width: 800px;
  margin: auto;
  padding: 2rem;
  position: relative;
  z-index: 1;
}

tw-passage {
  margin-bottom: 1.5rem;
}

.highlight {
